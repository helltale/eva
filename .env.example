# Copy to .env and adjust. Used by docker compose and local runs.

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
PUBLIC_BASE_URL=https://localhost
PUBLIC_HOST=localhost

# Strong secret for JWT signing (required)
JWT_SECRET=change-me-to-a-long-random-string

POSTGRES_USER=eva
POSTGRES_PASSWORD=eva
POSTGRES_DB=eva
# POSTGRES_DSN is composed in compose for backend container

REDIS_ADDR=localhost:6379

# openai_compat + Ollama default API: /v1/chat/completions
LLM_PROVIDER=openai_compat
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=120

SEARCH_PROVIDER=duckduckgo_html
SEARCH_BASE_URL=

STT_PROVIDER=noop
STT_BASE_URL=

TTS_PROVIDER=noop
TTS_BASE_URL=
# Short WAV beep on WS when TTS is noop (set false to silence)
TTS_NOOP_BEEP=true
DEFAULT_VOICE_NAME=default

CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:5173
LOG_LEVEL=info
