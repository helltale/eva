{
  "document_type": "technical_specification",
  "version": "1.1.0",
  "language": "ru",
  "target_consumer": "Cursor",
  "project": {
    "name": "lan_voice_assistant",
    "display_name": "Self-hosted LAN Voice Assistant",
    "summary": "Self-hosted ассистент для локальной сети с web-first клиентом, подготовленной архитектурой для desktop и mobile, текстовым и голосовым режимами, локальным запуском через Docker Compose, contract-first API, OpenAPI для внешнего HTTP API, gRPC для внутреннего взаимодействия и поддержкой человеческого голосового ответа через TTS.",
    "primary_goal": "Собрать pet project ассистента, который можно запустить дома в локальной сети без обязательных платных внешних сервисов, с возможностью вести текстовый и голосовой диалог.",
    "product_positioning": "Web-first self-hosted assistant platform with text chat, voice input, human-like voice output, optional local LLM, and future-ready desktop/mobile clients."
  },
  "product_requirements": {
    "must_have": [
      "Self-hosted запуск в локальной сети",
      "Удобный запуск через Docker Compose",
      "Web-клиент как первая реализуемая платформа",
      "Архитектура, пригодная для desktop и mobile без перелома backend",
      "Текстовый чат с ассистентом",
      "Голосовой режим с человеческим голосовым ответом",
      "Поддержка локальной LLM по умолчанию для бесплатного использования",
      "Возможность получать актуальные данные из интернета через поисковый сервис",
      "HTTP API наружу",
      "OpenAPI contract-first",
      "Генерация Go-типов и серверных интерфейсов из OpenAPI",
      "Генерация TypeScript client/types из OpenAPI",
      "gRPC для внутренних синхронных вызовов между сервисами",
      "Kafka не использовать в MVP, но заложить возможность добавить позже",
      "Reverse proxy с HTTPS/TLS для работы web-микрофона",
      "Хранение истории диалогов",
      "Базовая система настроек пользователя",
      "Наблюдаемость: healthcheck, logs, basic metrics",
      "TTS как штатный модуль архитектуры, а не опция",
      "Потоковая озвучка ответа ассистента",
      "Interrupt/barge-in: пользователь может перебить ассистента во время речи",
      "Настройки голоса ассистента: голос, язык, скорость, громкость, автопроигрывание",
      "Поддержка синхронизации текстового и голосового ответа"
    ],
    "nice_to_have": [
      "Wake word позже",
      "Desktop shell через Tauri позже",
      "Mobile shell через Capacitor или Tauri позже",
      "Память пользователя",
      "Интеграции с заметками, календарем, файлами",
      "RAG по локальным документам",
      "Фоновая обработка задач",
      "Event bus позже",
      "Несколько голосовых персон",
      "SSML или voice-style hints позже",
      "Настройки эмоциональности и тона голоса позже"
    ],
    "out_of_scope_for_mvp": [
      "Сложная multi-tenant модель",
      "Kubernetes",
      "Kafka в обязательной поставке",
      "Собственная обученная модель",
      "Always-on wake word в web-клиенте",
      "Полностью автономный mobile offline-first клиент",
      "Глубокие системные действия на desktop/mobile в первой версии",
      "Продвинутая эмоциональная актерская озвучка как обязательное условие MVP"
    ]
  },
  "global_constraints": {
    "cost_policy": {
      "goal": "Не использовать обязательные платные внешние сервисы",
      "default_llm_mode": "local",
      "default_stt_mode": "local",
      "default_tts_mode": "local",
      "cloud_integrations": "optional_disabled_by_default"
    },
    "deployment": {
      "mode": "self_hosted_lan",
      "orchestration": "docker_compose",
      "reverse_proxy": "caddy",
      "https_required_for_web_voice": true
    },
    "architecture": {
      "external_api_protocol": "http_json_openapi",
      "realtime_protocol": "websocket",
      "internal_sync_protocol": "grpc",
      "internal_async_protocol_future": "kafka_optional_later",
      "mvp_shape": "modular_monolith_plus_sidecars",
      "target_shape": "service_oriented_modular_system"
    },
    "implementation_language": {
      "backend": "golang",
      "frontend": "typescript"
    }
  },
  "business_assumptions": [
    "В системе изначально может быть один основной пользователь-администратор",
    "Сервис работает в домашней или офисной локальной сети",
    "Интернет может быть доступен не всегда, поэтому архитектура должна иметь деградацию до локального режима",
    "Требуется web-first UX, но нельзя проектировать backend только под web",
    "Голосовые функции должны работать по возможности через локальные движки",
    "Голосовой ответ ассистента является важной частью продукта и должен быть учтен уже в MVP-архитектуре"
  ],
  "high_level_decisions": {
    "architecture_style": "modular_monolith_first",
    "reasoning": [
      "Для pet project проще поднять и сопровождать один backend-процесс с хорошо отделенными модулями",
      "Сложные сервисные границы сохраняются на уровне пакетов и контрактов",
      "Вынесение в отдельные процессы возможно позже без изменения внешнего API",
      "Локальные sidecar-сервисы для LLM, STT и TTS допускаются уже в MVP"
    ],
    "llm_strategy": {
      "default": "local_llm_via_provider_adapter",
      "cloud_optional": true,
      "providers_required": [
        "local_provider",
        "cloud_provider_optional"
      ],
      "provider_abstraction_required": true
    },
    "internet_facts_strategy": {
      "default": "tool_based_search",
      "requirements": [
        "LLM не должна выдавать актуальные интернет-факты без вызова search tool",
        "Поиск должен быть отделен от LLM и доступен как отдельный модуль",
        "При отсутствии интернета ассистент должен корректно сообщать, что онлайн-данные недоступны"
      ]
    },
    "voice_output_strategy": {
      "default": "human_like_tts",
      "requirements": [
        "Голосовой ответ должен быть естественным и человеческим по тембру и темпу",
        "Озвучка должна поддерживать потоковую выдачу аудио",
        "Пользователь должен иметь возможность перебить озвучивание",
        "Текст ответа и голосовой ответ должны формироваться согласованно",
        "Система должна поддерживать переключаемые TTS providers через единый интерфейс"
      ]
    },
    "api_contract_strategy": {
      "approach": "contract_first",
      "public_api_source_of_truth": "openapi_yaml",
      "internal_api_source_of_truth": "proto_files",
      "generated_artifacts": [
        "Go HTTP server interfaces and models",
        "TypeScript client and models",
        "Go gRPC clients and servers"
      ]
    }
  },
  "system_context": {
    "external_clients": [
      "web",
      "desktop_future",
      "mobile_future"
    ],
    "core_backend_modules": [
      "api",
      "realtime_gateway",
      "assistant_core",
