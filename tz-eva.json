  "recommended_runtime_topology": {
    "mvp_runtime": [
      {
        "name": "caddy",
        "type": "container",
        "required": true,
        "responsibility": "TLS termination, reverse proxy, static routing"
      },
      {
        "name": "web",
        "type": "container",
        "required": true,
        "responsibility": "React web application"
      },
      {
        "name": "backend",
        "type": "container",
        "required": true,
        "responsibility": "HTTP API, WebSocket realtime gateway, assistant orchestration, auth, settings, history, voice orchestration"
      },
      {
        "name": "postgres",
        "type": "container",
        "required": true,
        "responsibility": "Persistent relational storage"
      },
      {
        "name": "redis",
        "type": "container",
        "required": true,
        "responsibility": "Ephemeral state, rate limiting, session cache, pub/sub if needed"
      },
      {
        "name": "local_llm",
