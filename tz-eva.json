    "future_portability_rules": [
      "Не использовать браузерно-специфичные API напрямую в бизнес-логике UI",
      "Вынести доступ к микрофону в adapter layer",
      "Вынести воспроизведение аудио в adapter layer",
      "Вынести realtime transport в adapter layer",
      "Подготовить shared UI/domain слой для desktop/mobile"
    ]
  },
  "desktop_mobile_readiness": {
    "requirement": "Архитектура должна поддерживать desktop и mobile без смены backend API",
    "rules": [
      "Public HTTP API и realtime protocol должны быть общими для всех клиентов",
      "Клиентские различия должны находиться только в platform adapters",
      "Shared client SDK обязателен",
      "Не допускать backend ветвления по типу клиента, кроме незначительных capability flags",
      "Голосовой ответ должен поддерживаться на всех будущих клиентах через единый voice protocol"
    ],
    "future_targets": {
      "desktop": "tauri",
      "mobile": "capacitor_or_tauri_mobile"
    }
  },
  "api_contracts": {
    "public_http_api": {
      "style": "REST JSON",
      "source_of_truth": "openapi/openapi.yaml",
      "versioning": "v1 in URL path",
      "must_expose_openapi": true,
      "openapi_endpoint": "/api/openapi.json",
      "generation_rules": {
        "backend": "generate Go models and server interfaces from OpenAPI",
        "frontend": "generate TypeScript client and types from OpenAPI",
        "manual_type_duplication_forbidden": true
      },
      "required_paths": [
        {
          "path": "/api/v1/health/live",
          "method": "GET",
          "purpose": "liveness"
        },
        {
          "path": "/api/v1/health/ready",
          "method": "GET",
          "purpose": "readiness"
        },
        {
          "path": "/api/v1/auth/login",
          "method": "POST",
          "purpose": "login by email_or_username and password"
        },
        {
          "path": "/api/v1/auth/refresh",
          "method": "POST",
          "purpose": "refresh access token"
        },
        {
          "path": "/api/v1/me",
          "method": "GET",
          "purpose": "current user profile"
        },
        {
          "path": "/api/v1/settings",
          "method": "GET",
          "purpose": "read user settings"
        },
        {
          "path": "/api/v1/settings",
          "method": "PATCH",
          "purpose": "update user settings"
        },
        {
          "path": "/api/v1/conversations",
          "method": "GET",
          "purpose": "list conversations"
        },
        {
          "path": "/api/v1/conversations",
          "method": "POST",
          "purpose": "create conversation"
        },
        {
          "path": "/api/v1/conversations/{conversationId}",
          "method": "GET",
          "purpose": "conversation metadata"
        },
        {
          "path": "/api/v1/conversations/{conversationId}/messages",
          "method": "GET",
          "purpose": "conversation messages"
        },
        {
          "path": "/api/v1/chat/messages",
          "method": "POST",
          "purpose": "text chat request-response or server-stream option if supported"
        },
        {
          "path": "/api/v1/tools",
          "method": "GET",
          "purpose": "list available tools and capabilities"
        },
        {
          "path": "/api/v1/voices",
          "method": "GET",
          "purpose": "list available TTS voice profiles"
        }
      ]
    },
    "realtime_api": {
      "transport": "websocket",
      "endpoint": "/ws/v1/realtime",
      "authentication": "bearer_token_query_or_header_during_upgrade",
      "message_format": "json envelopes for control/text + binary or base64 frames for audio, choose one implementation and keep protocol versioned",
      "required_client_events": [
        "session.start",
        "session.stop",
        "text.message",
        "audio.chunk",
        "audio.commit",
        "interrupt",
        "tts.stop",
        "ping"
      ],
      "required_server_events": [
        "session.started",
        "session.stopped",
        "stt.partial",
        "stt.final",
        "assistant.delta",
        "assistant.message",
        "tts.started",
        "tts.chunk",
        "tts.finished",
        "tool.started",
        "tool.finished",
        "error",
        "pong"
      ],
      "protocol_rules": [
        "Все события должны содержать type, requestId, sessionId, timestamp",
        "Должна быть version field на уровне envelope",
        "Ошибки должны иметь machine-readable code и human-readable message",
        "Interrupt должен прерывать текущую генерацию и TTS playback",
        "TTS audio chunks должны приходить в порядке воспроизведения",
        "Клиент должен иметь возможность остановить только озвучку без уничтожения всей сессии"
      ]
    },
    "internal_grpc_api": {
      "source_of_truth": "proto/*.proto",
      "services_required": [
        {
          "name": "LLMGatewayService",
          "methods": [
            "Generate",
            "StreamGenerate"
          ]
        },
        {
          "name": "SearchService",
          "methods": [
            "Search",
            "FetchPage"
          ]
        },
        {
          "name": "STTService",
          "methods": [
            "StreamRecognize"
          ]
        },
        {
          "name": "TTSService",
          "methods": [
            "Synthesize",
            "StreamSynthesize",
            "ListVoices"
          ]
        },
        {
          "name": "MemoryService",
          "methods": [
            "StoreMemory",
            "SearchMemory"
          ]
        }
      ],
      "rules": [
        "gRPC обязателен для внутренних синхронных вызовов между выделенными сервисами",
        "В MVP допустима in-process реализация с сохранением proto contracts для будущего выделения",
        "Streaming обязателен для STT и желателен для LLM/TTS",
