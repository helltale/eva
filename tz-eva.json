      {
        "name": "auth",
        "responsibilities": [
          "login",
          "refresh token",
          "user session validation",
          "password hashing",
          "JWT issuing"
        ]
      },
      {
        "name": "users",
        "responsibilities": [
          "user profile",
          "settings retrieval and update"
        ]
      },
      {
        "name": "conversations",
        "responsibilities": [
          "create conversation",
          "list conversation",
          "message history",
          "message persistence"
        ]
      },
      {
        "name": "assistant_core",
        "responsibilities": [
          "chat orchestration",
          "routing between LLM and tools",
          "prompt building",
          "conversation state",
          "response normalization"
        ]
      },
      {
        "name": "llm_gateway",
        "responsibilities": [
          "provider abstraction",
          "model routing",
          "request normalization",
          "streaming support"
        ]
      },
      {
        "name": "search",
        "responsibilities": [
          "web search",
          "page fetch",
          "source extraction",
          "timeout and safe failure"
        ]
      },
      {
        "name": "voice",
        "responsibilities": [
          "realtime session state",
          "stt integration",
          "tts integration",
          "interrupt handling",
          "audio event protocol",
          "text and audio synchronization"
